TOKEN=put_your_discord_bot_token_here
CLIENT_ID=put_your_discord_application_client_id_here
PORT=10000

# Dashboard OAuth2 (Discord Developer Portal → your app → OAuth2)
CLIENT_SECRET=put_your_discord_oauth2_client_secret_here
SESSION_SECRET=put_any_long_random_string_here

# The Discord server ID the dashboard checks for staff roles
GUILD_ID=put_your_server_id_here

# Full public URL of your dashboard (no trailing slash)
DASHBOARD_URL=https://yourbot.pebblehost.com

# Optional: persistent data directory path on hosts that support it
# DATA_DIR=/home/container/data
