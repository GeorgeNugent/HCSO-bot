<%- include('partials/header') %>

<style>
  .owner-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 12px;
    margin-top: 14px;
  }
  .owner-field label {
    display: block;
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .owner-field select {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 8px;
    padding: 10px;
    font-size: 14px;
  }
  .roles-wrap {
    margin-top: 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px;
    background: var(--surface2);
  }
  .roles-wrap label {
    display: block;
    margin-bottom: 8px;
    color: var(--text-muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .roles-select {
    width: 100%;
    min-height: 280px;
    background: #0f1420;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px;
  }
  .owner-help {
    color: var(--text-muted);
    font-size: 12px;
    margin-top: 8px;
  }
  .selected-pills {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .selected-pill {
    display: inline-block;
    border: 1px solid #2f4f7d;
    background: rgba(59,130,246,0.14);
    color: #9cc2ff;
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 12px;
  }
</style>

<div class="page-header">
  <h2 class="page-title">👑 Bot Owner Access</h2>
  <p class="page-subtitle">Configure dashboard segment visibility, suggestion reviewers, and application reviewers per server.</p>
</div>

<div class="section-card">
  <p class="section-desc">Signed in as: <code><%= currentUserId || 'unknown' %></code> | Bot Owner ID: <code><%= botOwnerId %></code></p>
  <p class="section-desc">Role source server: <code><%= roleSourceGuildId %></code></p>

  <% if (!isBotOwner) { %>
    <div class="alert alert-danger" style="margin-top:12px;">Only Bot Owner can edit this page.</div>
  <% } else { %>
    <div class="owner-grid">
      <div class="owner-field">
        <label>Server</label>
        <select id="serverSelect">
          <% (serverOptions || []).forEach(function(server){ %>
            <option value="<%= server.id %>" <%= String(selectedServerId || '') === String(server.id) ? 'selected' : '' %>><%= server.name %> (<%= server.id %>)</option>
          <% }); %>
        </select>
      </div>
      <div class="owner-field">
        <label>Dashboard Segment</label>
        <select id="segmentSelect">
          <% segmentKeys.forEach(function(seg) { %>
            <option value="<%= seg %>"><%= seg.charAt(0).toUpperCase() + seg.slice(1) %></option>
          <% }); %>
        </select>
      </div>
    </div>

    <div class="roles-wrap">
      <label>Allowed Roles (multi-select)</label>
      <select id="rolesSelect" class="roles-select" multiple></select>
      <div class="owner-help">Tip: hold Ctrl (or Cmd) to select multiple roles quickly.</div>
      <div id="selectedPills" class="selected-pills"></div>
    </div>

    <div class="roles-wrap">
      <label>Suggestion Reviewer Roles (multi-select)</label>
      <select id="suggestionRolesSelect" class="roles-select" multiple></select>
      <div class="owner-help">Only these roles (plus admins/Bot Owner) can approve or deny suggestions.</div>
      <div id="suggestionSelectedPills" class="selected-pills"></div>
    </div>

    <div class="roles-wrap">
      <label>Application Reviewer Roles (multi-select)</label>
      <select id="applicationRolesSelect" class="roles-select" multiple></select>
      <div class="owner-help">Only these roles (plus admins/Bot Owner) can review applications.</div>
      <div id="applicationSelectedPills" class="selected-pills"></div>
    </div>

    <div style="display:flex;gap:10px;align-items:center;margin-top:14px;">
      <button type="button" class="btn btn-info" id="saveOwnerAccessBtn">Save Segment Access</button>
      <button type="button" class="btn btn-info" id="saveSuggestionReviewersBtn">Save Suggestion Reviewers</button>
      <button type="button" class="btn btn-info" id="saveApplicationReviewersBtn">Save Application Reviewers</button>
      <a href="/settings" class="btn btn-outline">Back to Settings</a>
    </div>
    <div id="ownerAccessResult" class="inline-result" style="display:none;margin-top:10px;"></div>
    <div id="suggestionReviewerResult" class="inline-result" style="display:none;margin-top:10px;"></div>
    <div id="applicationReviewerResult" class="inline-result" style="display:none;margin-top:10px;"></div>
  <% } %>
</div>

<script id="ownerAccessData" type="application/json"><%- JSON.stringify({
  segmentAccess: cfg.dashboardSegmentAccess || {},
  segmentAccessByGuild: cfg.dashboardSegmentAccessByGuild || {},
  suggestionReviewerRoleIds: cfg.suggestionReviewerRoleIds || [],
  suggestionReviewerRoleIdsByGuild: cfg.suggestionReviewerRoleIdsByGuild || {},
  applicationReviewerRoleIds: cfg.applicationReviewerRoleIds || [],
  applicationReviewerRoleIdsByGuild: cfg.applicationReviewerRoleIdsByGuild || {},
  segmentKeys,
  selectedServerId,
  serverOptions,
  availableRolesByGuild
}) %></script>

<script>
(function () {
  var dataEl = document.getElementById('ownerAccessData');
  if (!dataEl) return;

  var parsed = JSON.parse(dataEl.textContent || '{}');
  var legacySegmentAccess = parsed.segmentAccess || {};
  var segmentAccessByGuild = parsed.segmentAccessByGuild || {};
  var legacySuggestionReviewerRoleIds = Array.isArray(parsed.suggestionReviewerRoleIds) ? parsed.suggestionReviewerRoleIds : [];
  var suggestionReviewerRoleIdsByGuild = parsed.suggestionReviewerRoleIdsByGuild || {};
  var legacyApplicationReviewerRoleIds = Array.isArray(parsed.applicationReviewerRoleIds) ? parsed.applicationReviewerRoleIds : [];
  var applicationReviewerRoleIdsByGuild = parsed.applicationReviewerRoleIdsByGuild || {};
  var segmentKeys = parsed.segmentKeys || [];
  var selectedServerId = parsed.selectedServerId || '';
  var serverOptions = parsed.serverOptions || [];
  var availableRolesByGuild = parsed.availableRolesByGuild || {};

  var serverSelect = document.getElementById('serverSelect');
  var segmentSelect = document.getElementById('segmentSelect');
  var rolesSelect = document.getElementById('rolesSelect');
  var suggestionRolesSelect = document.getElementById('suggestionRolesSelect');
  var applicationRolesSelect = document.getElementById('applicationRolesSelect');
  var resultEl = document.getElementById('ownerAccessResult');
  var suggestionResultEl = document.getElementById('suggestionReviewerResult');
  var applicationResultEl = document.getElementById('applicationReviewerResult');
  var saveBtn = document.getElementById('saveOwnerAccessBtn');
  var saveSuggestionBtn = document.getElementById('saveSuggestionReviewersBtn');
  var saveApplicationBtn = document.getElementById('saveApplicationReviewersBtn');
  var pills = document.getElementById('selectedPills');
  var suggestionPills = document.getElementById('suggestionSelectedPills');
  var applicationPills = document.getElementById('applicationSelectedPills');

  if (!serverSelect || !segmentSelect || !rolesSelect || !suggestionRolesSelect || !applicationRolesSelect || !saveBtn || !saveSuggestionBtn || !saveApplicationBtn || !pills || !suggestionPills || !applicationPills) return;

  function getCurrentServerId() {
    return serverSelect.value;
  }

  function getRolesForCurrentServer() {
    var serverId = getCurrentServerId();
    return Array.isArray(availableRolesByGuild[serverId]) ? availableRolesByGuild[serverId] : [];
  }

  function getSegmentAccessForCurrentServer() {
    var serverId = getCurrentServerId();
    if (!segmentAccessByGuild[serverId] || typeof segmentAccessByGuild[serverId] !== 'object') {
      segmentAccessByGuild[serverId] = {};
    }
    return segmentAccessByGuild[serverId];
  }

  function getSuggestionRolesForCurrentServer() {
    var serverId = getCurrentServerId();
    if (!Array.isArray(suggestionReviewerRoleIdsByGuild[serverId])) {
      suggestionReviewerRoleIdsByGuild[serverId] = serverId === selectedServerId ? legacySuggestionReviewerRoleIds.slice() : [];
    }
    return suggestionReviewerRoleIdsByGuild[serverId];
  }

  function getApplicationRolesForCurrentServer() {
    var serverId = getCurrentServerId();
    if (!Array.isArray(applicationReviewerRoleIdsByGuild[serverId])) {
      applicationReviewerRoleIdsByGuild[serverId] = serverId === selectedServerId ? legacyApplicationReviewerRoleIds.slice() : [];
    }
    return applicationReviewerRoleIdsByGuild[serverId];
  }

  function getCurrentSegment() {
    return segmentSelect.value;
  }

  function normalizeAccess() {
    var current = getSegmentAccessForCurrentServer();
    segmentKeys.forEach(function (seg) {
      if (!Array.isArray(current[seg])) {
        current[seg] = Array.isArray(legacySegmentAccess[seg]) ? legacySegmentAccess[seg].slice() : [];
      }
    });
  }

  function renderRoleList() {
    var roles = getRolesForCurrentServer();
    var access = getSegmentAccessForCurrentServer();
    var seg = getCurrentSegment();
    var selectedIds = new Set(access[seg] || []);

    rolesSelect.innerHTML = '';
    roles.forEach(function (role) {
      var opt = document.createElement('option');
      opt.value = role.id;
      opt.textContent = role.name + ' (' + role.id + ')';
      opt.selected = selectedIds.has(role.id);
      rolesSelect.appendChild(opt);
    });

    renderPills();
  }

  function renderSuggestionRoleList() {
    var roles = getRolesForCurrentServer();
    var selectedIds = new Set(getSuggestionRolesForCurrentServer());

    suggestionRolesSelect.innerHTML = '';
    roles.forEach(function (role) {
      var opt = document.createElement('option');
      opt.value = role.id;
      opt.textContent = role.name + ' (' + role.id + ')';
      opt.selected = selectedIds.has(role.id);
      suggestionRolesSelect.appendChild(opt);
    });

    renderSuggestionPills();
  }

  function renderApplicationRoleList() {
    var roles = getRolesForCurrentServer();
    var selectedIds = new Set(getApplicationRolesForCurrentServer());

    applicationRolesSelect.innerHTML = '';
    roles.forEach(function (role) {
      var opt = document.createElement('option');
      opt.value = role.id;
      opt.textContent = role.name + ' (' + role.id + ')';
      opt.selected = selectedIds.has(role.id);
      applicationRolesSelect.appendChild(opt);
    });

    renderApplicationPills();
  }

  function renderPills() {
    var roles = getRolesForCurrentServer();
    var access = getSegmentAccessForCurrentServer();
    var seg = getCurrentSegment();
    var selectedIds = new Set(access[seg] || []);

    pills.innerHTML = '';
    if (selectedIds.size === 0) {
      var empty = document.createElement('span');
      empty.className = 'selected-pill';
      empty.textContent = 'No role restriction (all staff can view this segment)';
      pills.appendChild(empty);
      return;
    }

    roles
      .filter(function (r) { return selectedIds.has(r.id); })
      .forEach(function (role) {
        var chip = document.createElement('span');
        chip.className = 'selected-pill';
        chip.textContent = role.name;
        pills.appendChild(chip);
      });
  }

    function renderSuggestionPills() {
      var roles = getRolesForCurrentServer();
      var selectedIds = new Set(getSuggestionRolesForCurrentServer());

      suggestionPills.innerHTML = '';
      if (selectedIds.size === 0) {
        var empty = document.createElement('span');
        empty.className = 'selected-pill';
        empty.textContent = 'No custom roles selected (fallback defaults will be used)';
        suggestionPills.appendChild(empty);
        return;
      }

      roles
        .filter(function (r) { return selectedIds.has(r.id); })
        .forEach(function (role) {
          var chip = document.createElement('span');
          chip.className = 'selected-pill';
          chip.textContent = role.name;
          suggestionPills.appendChild(chip);
        });
    }

    function renderApplicationPills() {
      var roles = getRolesForCurrentServer();
      var selectedIds = new Set(getApplicationRolesForCurrentServer());

      applicationPills.innerHTML = '';
      if (selectedIds.size === 0) {
        var empty = document.createElement('span');
        empty.className = 'selected-pill';
        empty.textContent = 'No custom roles selected (fallback defaults will be used)';
        applicationPills.appendChild(empty);
        return;
      }

      roles
        .filter(function (r) { return selectedIds.has(r.id); })
        .forEach(function (role) {
          var chip = document.createElement('span');
          chip.className = 'selected-pill';
          chip.textContent = role.name;
          applicationPills.appendChild(chip);
        });
    }

  function updateSegmentSelection() {
    var access = getSegmentAccessForCurrentServer();
    var seg = getCurrentSegment();
    var selected = Array.from(rolesSelect.selectedOptions).map(function (o) { return o.value; });
    access[seg] = selected;
    renderPills();
  }

  function updateSuggestionSelection() {
    var serverId = getCurrentServerId();
    suggestionReviewerRoleIdsByGuild[serverId] = Array.from(suggestionRolesSelect.selectedOptions).map(function (o) { return o.value; });
    renderSuggestionPills();
  }

  function updateApplicationSelection() {
    var serverId = getCurrentServerId();
    applicationReviewerRoleIdsByGuild[serverId] = Array.from(applicationRolesSelect.selectedOptions).map(function (o) { return o.value; });
    renderApplicationPills();
  }

  function rerenderForServer() {
    normalizeAccess();
    renderRoleList();
    renderSuggestionRoleList();
    renderApplicationRoleList();
  }

  async function save() {
    resultEl.style.display = 'block';
    resultEl.className = 'inline-result';
    resultEl.textContent = 'Saving...';

    try {
      var response = await fetch('/api/settings/segment-access', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ serverId: getCurrentServerId(), segmentAccess: getSegmentAccessForCurrentServer() })
      });
      var data = await response.json();
      if (data.success) {
        resultEl.textContent = '✅ Segment access saved.';
        resultEl.classList.add('result-success');
      } else {
        resultEl.textContent = '❌ ' + (data.error || 'Failed');
        resultEl.classList.add('result-error');
      }
    } catch (e) {
      resultEl.textContent = '❌ Network error';
      resultEl.classList.add('result-error');
    }
  }

  async function saveSuggestionReviewers() {
    suggestionResultEl.style.display = 'block';
    suggestionResultEl.className = 'inline-result';
    suggestionResultEl.textContent = 'Saving...';

    try {
      var response = await fetch('/api/settings/suggestion-reviewers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ serverId: getCurrentServerId(), roleIds: getSuggestionRolesForCurrentServer() })
      });
      var data = await response.json();
      if (data.success) {
        suggestionResultEl.textContent = '✅ Suggestion reviewer roles saved.';
        suggestionResultEl.classList.add('result-success');
      } else {
        suggestionResultEl.textContent = '❌ ' + (data.error || 'Failed');
        suggestionResultEl.classList.add('result-error');
      }
    } catch (e) {
      suggestionResultEl.textContent = '❌ Network error';
      suggestionResultEl.classList.add('result-error');
    }
  }

  async function saveApplicationReviewers() {
    applicationResultEl.style.display = 'block';
    applicationResultEl.className = 'inline-result';
    applicationResultEl.textContent = 'Saving...';

    try {
      var response = await fetch('/api/settings/application-reviewers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ serverId: getCurrentServerId(), roleIds: getApplicationRolesForCurrentServer() })
      });
      var data = await response.json();
      if (data.success) {
        applicationResultEl.textContent = '✅ Application reviewer roles saved.';
        applicationResultEl.classList.add('result-success');
      } else {
        applicationResultEl.textContent = '❌ ' + (data.error || 'Failed');
        applicationResultEl.classList.add('result-error');
      }
    } catch (e) {
      applicationResultEl.textContent = '❌ Network error';
      applicationResultEl.classList.add('result-error');
    }
  }

  rerenderForServer();
  serverSelect.addEventListener('change', rerenderForServer);
  segmentSelect.addEventListener('change', renderRoleList);
  rolesSelect.addEventListener('change', updateSegmentSelection);
  suggestionRolesSelect.addEventListener('change', updateSuggestionSelection);
  applicationRolesSelect.addEventListener('change', updateApplicationSelection);
  saveBtn.addEventListener('click', save);
  saveSuggestionBtn.addEventListener('click', saveSuggestionReviewers);
  saveApplicationBtn.addEventListener('click', saveApplicationReviewers);
})();
</script>

<%- include('partials/footer') %>
