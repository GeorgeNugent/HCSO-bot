<%- include('partials/header') %>

<div class="page-header">
  <h2 class="page-title">⚡ Commands Panel</h2>
  <p class="page-subtitle">Trigger bot commands from the dashboard</p>
</div>

<!-- Tab buttons -->
<div class="tab-bar">
  <button class="tab-btn active" data-tab="moderation">🔨 Moderation</button>
  <button class="tab-btn"        data-tab="staffmgmt">🌴 Staff Mgmt</button>
  <button class="tab-btn"        data-tab="cases">📋 Cases</button>
  <button class="tab-btn"        data-tab="announce">📢 Announce</button>
</div>

<!-- ── MODERATION TAB ────────────────────────────────────────────────────── -->
<div class="tab-panel active" id="tab-moderation">

  <div class="cmd-grid">

    <!-- Strike -->
    <div class="cmd-card" id="cmd-moderation">
      <h4 class="cmd-title">⚖️ Add Strike</h4>
      <form class="cmd-form" data-endpoint="/api/commands/strike">
        <label>Member</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% members.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
        </select>
        <label>Reason</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason for strike" required>
        <button type="submit" class="btn btn-warn">Add Strike</button>
      </form>
    </div>

    <!-- Strike Remove -->
    <div class="cmd-card">
      <h4 class="cmd-title">✅ Remove Strike</h4>
      <form class="cmd-form" data-endpoint="/api/commands/strike-remove">
        <label>Member</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% members.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
        </select>
        <label>Amount to remove</label>
        <input type="number" name="amount" min="1" max="3" value="1" required>
        <button type="submit" class="btn btn-success">Remove Strike</button>
      </form>
    </div>

    <!-- Ban -->
    <div class="cmd-card">
      <h4 class="cmd-title">🚫 Ban Member</h4>
      <form class="cmd-form" data-endpoint="/api/commands/ban">
        <label>Member</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% members.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
        </select>
        <label>Reason</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason for ban" required>
        <button type="submit" class="btn btn-danger">Ban</button>
      </form>
    </div>

    <!-- Kick -->
    <div class="cmd-card">
      <h4 class="cmd-title">👢 Kick Member</h4>
      <form class="cmd-form" data-endpoint="/api/commands/kick">
        <label>Member</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% members.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
        </select>
        <label>Reason</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason for kick" required>
        <button type="submit" class="btn btn-danger">Kick</button>
      </form>
    </div>

    <!-- Timeout -->
    <div class="cmd-card">
      <h4 class="cmd-title">⏳ Timeout Member</h4>
      <form class="cmd-form" data-endpoint="/api/commands/timeout">
        <label>Member</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% members.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
        </select>
        <label>Duration (minutes)</label>
        <input type="number" name="minutes" min="1" max="40320" value="60" required>
        <label>Reason</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason (optional)">
        <button type="submit" class="btn btn-warn">Timeout</button>
      </form>
    </div>

    <!-- Unban -->
    <div class="cmd-card">
      <h4 class="cmd-title">🔓 Unban User</h4>
      <form class="cmd-form" data-endpoint="/api/commands/unban">
        <label>Discord User ID</label>
        <input type="text" name="userId" pattern="\d{17,20}" placeholder="e.g. 123456789012345678" required>
        <label>Reason</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason for unban">
        <button type="submit" class="btn btn-success">Unban</button>
      </form>
    </div>

    <!-- Purge -->
    <div class="cmd-card">
      <h4 class="cmd-title">🗑️ Purge Messages</h4>
      <form class="cmd-form" data-endpoint="/api/commands/purge">
        <label>Channel</label>
        <select name="channelId" required>
          <option value="">— Select channel —</option>
          <% channels.forEach(c => { %><option value="<%= c.id %>">#<%= c.name %> (<%= c.parent %>)</option><% }); %>
        </select>
        <label>Amount (max 100)</label>
        <input type="number" name="amount" min="1" max="100" value="10" required>
        <button type="submit" class="btn btn-danger">Purge</button>
      </form>
    </div>

  </div>
</div><!-- /tab-moderation -->

<!-- ── STAFF MGMT TAB ────────────────────────────────────────────────────── -->
<div class="tab-panel" id="tab-staffmgmt">
  <div class="cmd-grid">

    <!-- Set LOA -->
    <div class="cmd-card">
      <h4 class="cmd-title">🌴 Set LOA</h4>
      <form class="cmd-form" data-endpoint="/api/commands/loa">
        <label>Member</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% members.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
        </select>
        <label>Start Date (MM-DD-YYYY)</label>
        <input type="text" name="startDate" pattern="\d{2}-\d{2}-\d{4}" placeholder="e.g. 03-27-2026" required>
        <label>End Date (MM-DD-YYYY)</label>
        <input type="text" name="endDate"   pattern="\d{2}-\d{2}-\d{4}" placeholder="e.g. 04-10-2026" required>
        <label>Reason (optional)</label>
        <input type="text" name="reason" maxlength="256" placeholder="Reason for LOA">
        <button type="submit" class="btn btn-info">Set LOA</button>
      </form>
    </div>

    <!-- End LOA -->
    <div class="cmd-card">
      <h4 class="cmd-title">✅ End LOA</h4>
      <% if (usersOnLoa.length === 0) { %>
        <p class="empty-state">No members are currently on LOA.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/end-loa">
        <label>Member on LOA</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% usersOnLoa.forEach(u => { %><option value="<%= u.id %>"><%= u.name %></option><% }); %>
        </select>
        <button type="submit" class="btn btn-success">End LOA</button>
      </form>
      <% } %>
    </div>

  </div>
</div><!-- /tab-staffmgmt -->

<!-- ── CASES TAB ─────────────────────────────────────────────────────────── -->
<div class="tab-panel" id="tab-cases">
  <div class="cmd-grid">

    <!-- Create case -->
    <div class="cmd-card">
      <h4 class="cmd-title">🆕 Create Case</h4>
      <form class="cmd-form" data-endpoint="/api/commands/case-create">
        <label>Title</label>
        <input type="text" name="title" maxlength="128" placeholder="Case title" required>
        <label>Incident Type</label>
        <input type="text" name="incidentType" maxlength="128" placeholder="Traffic stop, robbery, etc." required>
        <label>Location</label>
        <input type="text" name="location" maxlength="128" placeholder="Incident location" required>
        <label>Suspect</label>
        <input type="text" name="suspect" maxlength="128" placeholder="Suspect name (optional)">
        <label>Summary</label>
        <textarea name="summary" rows="4" maxlength="1200" placeholder="Case summary" required></textarea>
        <button type="submit" class="btn btn-success">Create Case</button>
      </form>
    </div>

    <!-- View case -->
    <div class="cmd-card">
      <h4 class="cmd-title">📂 View Case</h4>
      <% if (allCases.length === 0) { %>
        <p class="empty-state">No cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/case-view">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% allCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
        </select>
        <button type="submit" class="btn btn-info">View Case</button>
      </form>
      <% } %>
    </div>

    <!-- Search cases -->
    <div class="cmd-card">
      <h4 class="cmd-title">🔎 Search Cases</h4>
      <form class="cmd-form" data-endpoint="/api/commands/case-search">
        <label>Search Query</label>
        <input type="text" name="query" maxlength="128" placeholder="ID, title, suspect, location..." required>
        <button type="submit" class="btn btn-info">Search</button>
      </form>
    </div>

    <!-- Assign case -->
    <div class="cmd-card">
      <h4 class="cmd-title">📌 Assign Case</h4>
      <% if (allCases.length === 0) { %>
        <p class="empty-state">No cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/case-assign">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% allCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
        </select>
        <label>Assign To</label>
        <select name="userId" required>
          <option value="">— Select member —</option>
          <% members.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
        </select>
        <label>Note (optional)</label>
        <input type="text" name="note" maxlength="512" placeholder="Assignment note">
        <button type="submit" class="btn btn-success">Assign</button>
      </form>
      <% } %>
    </div>

    <!-- Unassign case -->
    <div class="cmd-card">
      <h4 class="cmd-title">📎 Unassign Case</h4>
      <% if (allCases.length === 0) { %>
        <p class="empty-state">No cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/case-unassign">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% allCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
        </select>
        <label>Reason</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason for unassigning">
        <button type="submit" class="btn btn-warn">Unassign</button>
      </form>
      <% } %>
    </div>

    <!-- Add evidence -->
    <div class="cmd-card">
      <h4 class="cmd-title">📸 Add Evidence</h4>
      <% if (allCases.length === 0) { %>
        <p class="empty-state">No cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/evidence-add">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% allCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
        </select>
        <label>Description</label>
        <textarea name="description" rows="4" maxlength="1000" placeholder="Evidence details" required></textarea>
        <button type="submit" class="btn btn-info">Add Evidence</button>
      </form>
      <% } %>
    </div>

    <!-- Edit case -->
    <div class="cmd-card">
      <h4 class="cmd-title">✏️ Edit Case</h4>
      <% if (allCases.length === 0) { %>
        <p class="empty-state">No cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/case-edit">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% allCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
        </select>
        <label>Field</label>
        <select name="field" required>
          <option value="title">Title</option>
          <option value="incidentType">Incident Type</option>
          <option value="location">Location</option>
          <option value="suspect">Suspect</option>
          <option value="summary">Summary</option>
          <option value="status">Status (Open/Closed)</option>
          <option value="assignedTo">Assigned To (User ID)</option>
        </select>
        <label>Value</label>
        <input type="text" name="value" maxlength="1200" placeholder="New value" required>
        <button type="submit" class="btn btn-info">Update Case</button>
      </form>
      <% } %>
    </div>

    <!-- Close case -->
    <div class="cmd-card">
      <h4 class="cmd-title">📁 Close Case</h4>
      <% if (openCases.length === 0) { %>
        <p class="empty-state">No open cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/case-close">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% openCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %></option><% }); %>
        </select>
        <label>Closing reason (optional)</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason for closing">
        <button type="submit" class="btn btn-warn">Close Case</button>
      </form>
      <% } %>
    </div>

    <!-- Reopen case -->
    <div class="cmd-card">
      <h4 class="cmd-title">🔓 Reopen Case</h4>
      <% if (allCases.length === 0) { %>
        <p class="empty-state">No cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/case-reopen">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% allCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
        </select>
        <label>Reason</label>
        <input type="text" name="reason" maxlength="512" placeholder="Reason for reopening" required>
        <button type="submit" class="btn btn-success">Reopen Case</button>
      </form>
      <% } %>
    </div>

    <!-- Delete case -->
    <div class="cmd-card">
      <h4 class="cmd-title">🗑️ Delete Case</h4>
      <% if (allCases.length === 0) { %>
        <p class="empty-state">No cases found.</p>
      <% } else { %>
      <form class="cmd-form" data-endpoint="/api/commands/case-delete">
        <label>Case</label>
        <select name="caseId" required>
          <option value="">— Select case —</option>
          <% allCases.forEach(c => { %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
        </select>
        <label>Type YES to confirm</label>
        <input type="text" name="confirmation" maxlength="3" placeholder="YES" required>
        <button type="submit" class="btn btn-danger">Delete Case</button>
      </form>
      <% } %>
    </div>

  </div>
</div><!-- /tab-cases -->

<!-- ── ANNOUNCE TAB ───────────────────────────────────────────────────────── -->
<div class="tab-panel" id="tab-announce">
  <div class="cmd-grid">

    <div class="cmd-card" style="max-width:520px;">
      <h4 class="cmd-title">📢 Post Announcement</h4>
      <form class="cmd-form" data-endpoint="/api/commands/announce">
        <label>Server</label>
        <select name="serverId" id="announce-server" required>
          <option value="">— Select server —</option>
          <% servers.forEach(s => { %><option value="<%= s.id %>"><%= s.name %> (<%= s.shortName %>)</option><% }); %>
        </select>
        <label>Channel</label>
        <select name="channelId" id="announce-channel" required>
          <option value="">— Select channel —</option>
          <% channels.forEach(c => { %><option value="<%= c.id %>" data-guild-id="<%= c.guildId %>">#<%= c.name %> (<%= c.parent %>)</option><% }); %>
        </select>
        <label>Title (optional)</label>
        <input type="text" name="title" maxlength="256" placeholder="Announcement title">
        <label>Message</label>
        <textarea name="message" rows="5" maxlength="2000" placeholder="Write your announcement here..." required></textarea>
        <button type="submit" class="btn btn-success">Post Announcement</button>
      </form>
    </div>

  </div>
</div><!-- /tab-announce -->

<script>
  // Announcement server/channel filtering
  const channelsByServer = <%- JSON.stringify(channelsByServer) %>;
  
  const serverSelect = document.getElementById("announce-server");
  const channelSelect = document.getElementById("announce-channel");
  
  if (serverSelect && channelSelect) {
    serverSelect.addEventListener("change", (e) => {
      const selectedServerId = e.target.value;
      channelSelect.innerHTML = '<option value="">— Select channel —</option>';
      
      if (selectedServerId && channelsByServer[selectedServerId]) {
        channelsByServer[selectedServerId].forEach(channel => {
          const option = document.createElement("option");
          option.value = channel.id;
          option.textContent = `#${channel.name} (${channel.parent})`;
          channelSelect.appendChild(option);
        });
      }
    });
  }

  // Tab switching
  document.querySelectorAll(".tab-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      document.querySelectorAll(".tab-panel").forEach(p => p.classList.remove("active"));
      btn.classList.add("active");
      document.getElementById("tab-" + btn.dataset.tab).classList.add("active");
    });
  });

  // Handle anchor navigation (e.g., /commands#moderation)
  const hash = location.hash.replace("#", "");
  if (hash) {
    const btn = document.querySelector(`.tab-btn[data-tab="${hash}"]`);
    if (btn) btn.click();
  }
</script>

<%- include('partials/footer') %>
