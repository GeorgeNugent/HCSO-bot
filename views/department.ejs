<%- include('partials/header') %>

<style>
  :root {
    --dept-color:     <%= dept.color %>;
    --dept-color-a13: <%= dept.color %>22;
    --dept-color-a26: <%= dept.color %>44;
  }
  .dept-header        { border-left: 4px solid var(--dept-color); padding-left: 16px; }
  .dept-icon-img      { width:64px;height:64px;border-radius:50%;border:3px solid var(--dept-color); }
  .dept-icon-placeholder {
    width:64px;height:64px;border-radius:50%;
    background:var(--dept-color-a13);border:3px solid var(--dept-color);
    display:flex;align-items:center;justify-content:center;font-size:28px;
  }
  .dept-color-display { color: var(--dept-color); }
  .dept-color-swatch  { width:16px;height:16px;border-radius:3px;background:var(--dept-color);display:inline-block; }
  .member-avatar      { width:32px;height:32px;border-radius:50%;vertical-align:middle;margin-right:8px; }
  .strike-pip         { display:inline-block;width:10px;height:10px;border-radius:50%;background:#e74c3c;margin-right:2px; }
  .strike-pip.empty   { background:var(--border); }
  .modal-overlay      { display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;align-items:center;justify-content:center; }
  .modal-overlay.open { display:flex; }
  .modal-box          { background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:28px;min-width:340px;max-width:460px;width:100%; }
  .modal-title        { font-size:18px;font-weight:700;color:var(--text-primary);margin-bottom:16px; }
  .form-group         { margin-bottom:14px; }
  .form-group label   { display:block;font-size:12px;color:var(--text-muted);margin-bottom:4px; }
  .member-search      { width:100%;padding:8px 12px;background:var(--surface);border:1px solid var(--border);border-radius:6px;color:var(--text-primary);font-size:14px;margin-bottom:12px; }
  .action-btns        { display:flex;gap:8px;flex-wrap:wrap; }
  .btn-strike  { background:#e67e22;color:#fff;border:none; }
  .btn-kick    { background:#c0392b;color:#fff;border:none; }
  .btn-timeout { background:#8e44ad;color:#fff;border:none; }
  .btn-ban     { background:#2c3e50;color:#fff;border:none; }
    .btn-strike-remove { background:#555;color:#fff;border:none; }
  #memberTable {
    width: 100%;
    min-width: 1180px;
    border-collapse: separate;
    border-spacing: 0;
  }
  #memberTable th {
    text-align: left;
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 10px 10px;
    border-bottom: 1px solid var(--border);
  }
  #memberTable td {
    padding: 12px 10px;
    border-bottom: 1px solid var(--border)50;
    vertical-align: middle;
  }
  #memberTable .col-member  { width: 27%; min-width: 240px; }
  #memberTable .col-roles   { width: 35%; min-width: 320px; }
  #memberTable .col-strikes { width: 11%; min-width: 120px; }
  #memberTable .col-joined  { width: 10%; min-width: 110px; }
  #memberTable .col-actions { width: 17%; min-width: 220px; }
  .role-cell {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .role-pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 3px 9px;
    font-size: 11px;
    color: var(--text-muted);
    background: var(--surface2);
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<!-- Header -->
<div class="page-header dept-header">
  <div style="display:flex;align-items:center;gap:16px;">
    <% if (detail.icon) { %>
      <img src="<%= detail.icon %>" alt="" class="dept-icon-img" onerror="this.style.display='none'">
    <% } else { %>
      <div class="dept-icon-placeholder">🏛️</div>
    <% } %>
    <div>
      <h2 class="page-title" style="margin:0;"><%= dept.name %></h2>
      <p class="page-subtitle" style="margin:4px 0 0;">
        <%= detail.name %> &nbsp;·&nbsp; <%= detail.memberCount.toLocaleString() %> members
    <!-- Tab bar -->
    <div class="tab-bar" style="margin-bottom:0;border-bottom:none;padding-bottom:0;">
      <button class="tab-btn active" data-dtab="dtab-members">👥 Members</button>
      <button class="tab-btn" data-dtab="dtab-cases">📋 Cases</button>
      <button class="tab-btn" data-dtab="dtab-loa">🌴 LOA Manager</button>
      <button class="tab-btn" data-dtab="dtab-logs">📋 View Logs</button>
    </div>

    <!-- ─── Members tab panel ─────────────────────────────────────────────── -->
    <div id="dtab-members" class="tab-panel active">
    <!-- Member list -->
    <div class="card">
    </div>
  </div>
</div>

<!-- Stats row -->
<div class="stats-grid" style="margin-bottom:24px;">
  <div class="stat-card">
    <div class="stat-icon">👥</div>
    <div class="stat-body">
      <div class="stat-value"><%= detail.memberCount.toLocaleString() %></div>
      <div class="stat-label">Total Members</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">👤</div>
    <div class="stat-body">
      <div class="stat-value"><%= members.length %></div>
      <div class="stat-label">Loaded</div>
    </div>
  </div>
  <div class="stat-card stat-card--ok">
    <div class="stat-icon">🟢</div>
    <div class="stat-body">
      <div class="stat-value"><%= detail.online ? 'Online' : 'Offline' %></div>
      <div class="stat-label">Bot Status</div>
    </div>
  </div>
  <div class="stat-card stat-card--warn">
    <div class="stat-icon">⚖️</div>
    <div class="stat-body">
      <div class="stat-value"><%= members.reduce(function(s,m){return s+m.strikeCount},0) %></div>
      <div class="stat-label">Total Strikes</div>
    </div>
  </div>
</div>

<!-- Member list -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">👥 Members</h3>
  </div>
  <div class="card-body" style="padding-top:12px;">
    <input type="text" id="memberSearch" class="member-search" placeholder="🔍  Search members…" oninput="filterMembers()">
    <% if (members.length === 0) { %>
      <p style="color:var(--text-muted);padding:12px 0;">
        No members loaded.
        <% if (memberLoadError) { %>
          Error: <%= memberLoadError %>
        <% } else { %>
          Bot may not have access to fetch members for this server.
        <% } %>
      </p>
    <% } else { %>
    <div style="overflow-x:auto;">
      <table class="table" id="memberTable">
        <thead>
          <tr>
            <th class="col-member">Member</th>
            <th class="col-roles">Roles</th>
            <th class="col-strikes">Strikes</th>
            <th class="col-joined">Joined</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% members.forEach(function(m) { %>
          <tr data-name="<%= m.name.toLowerCase() %>" data-username="<%= m.username.toLowerCase() %>">
            <td class="col-member">
              <img src="<%= m.avatar %>" alt="" class="member-avatar" onerror="this.style.display='none'">
              <span style="font-weight:600;color:var(--text-primary);"><%= m.name %></span>
              <% if (m.timedOut) { %><span class="badge" style="background:#8e44ad22;color:#8e44ad;margin-left:4px;">⏱ Timed out</span><% } %>
            </td>
            <td class="col-roles" style="font-size:12px;color:var(--text-muted);">
              <div class="role-cell">
                <span class="role-pill" title="<%= m.highestRole %>"><%= m.highestRole %></span>
              </div>
            </td>
            <td class="col-strikes">
              <% for(var i=0;i<MAX_STRIKES;i++){ %>
                <span class="strike-pip <%= i < m.strikeCount ? '' : 'empty' %>"></span>
              <% } %>
              <span style="font-size:11px;color:var(--text-muted);margin-left:4px;"><%= m.strikeCount %>/<%= MAX_STRIKES %></span>
            </td>
            <td class="col-joined" style="font-size:12px;color:var(--text-muted);"><%= m.joinedAt %></td>
            <td class="col-actions">
              <div class="action-btns">
                <button class="btn btn-sm btn-strike"  data-action="strike"  data-id="<%= m.id %>" data-name="<%= m.name %>" onclick="openModal(this.dataset.action,this.dataset.id,this.dataset.name)">⚖️ Strike</button>
                <button class="btn btn-sm btn-timeout" data-action="timeout" data-id="<%= m.id %>" data-name="<%= m.name %>" onclick="openModal(this.dataset.action,this.dataset.id,this.dataset.name)">⏱ Timeout</button>
                <button class="btn btn-sm btn-kick"    data-action="kick"    data-id="<%= m.id %>" data-name="<%= m.name %>" onclick="openModal(this.dataset.action,this.dataset.id,this.dataset.name)">👢 Kick</button>
                <button class="btn btn-sm btn-ban"     data-action="ban"     data-id="<%= m.id %>" data-name="<%= m.name %>" onclick="openModal(this.dataset.action,this.dataset.id,this.dataset.name)">🔨 Ban</button>
                  <button class="btn btn-sm btn-strike-remove" data-action="strike-remove" data-id="<%= m.id %>" data-name="<%= m.name %>" onclick="openModal(this.dataset.action,this.dataset.id,this.dataset.name)">❌ Remove Strike</button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<div style="margin-top:16px;">
  <a href="/servers" class="btn btn-outline">← Back to All Servers</a>
</div>

<!-- ── Action modal ───────────────────────────────────────────────────────── -->
</div><!-- end dtab-members -->

<!-- ─── Cases tab panel ──────────────────────────────────────────────────── -->
<div id="dtab-cases" class="tab-panel">
  <% if ((deptCases||[]).length === 0) { %>
    <p style="color:var(--text-muted);padding:8px 0;">No cases for this department yet. Create one below.</p>
  <% } %>
  <div class="cmd-grid">
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">🆕</span><div class="cmd-card-title">Create Case</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Title</label><input class="form-control" id="dc-title" placeholder="Case title…"></div>
        <div class="form-group"><label>Incident Type</label><input class="form-control" id="dc-type" placeholder="e.g. Traffic Stop"></div>
        <div class="form-group"><label>Location</label><input class="form-control" id="dc-loc" placeholder="Location…"></div>
        <div class="form-group"><label>Suspect (optional)</label><input class="form-control" id="dc-suspect" placeholder="Unknown"></div>
        <div class="form-group"><label>Summary</label><textarea class="form-control" id="dc-summary" rows="3" placeholder="Brief summary…"></textarea></div>
        <div class="form-group" style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
          <input type="checkbox" id="dc-joint" style="width:auto;margin:0;">
          <label for="dc-joint" style="margin:0;color:var(--text);cursor:pointer;">🤝 Joint Ops — visible to all departments</label>
        </div>
        <button class="btn btn-primary btn-sm" onclick="deptCaseCreate()">Create</button>
        <div id="dc-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">📂</span><div class="cmd-card-title">View Case</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Case</label>
          <select class="form-control" id="dc-view-id">
            <% (deptCases||[]).forEach(function(c){ %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %> (<%= c.status %>)</option><% }); %>
          </select>
        </div>
        <button class="btn btn-primary btn-sm" onclick="deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/case-view',{caseId:document.getElementById('dc-view-id').value},'dc-view-result')">View</button>
        <div id="dc-view-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">📁</span><div class="cmd-card-title">Close Case</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Case</label>
          <select class="form-control" id="dc-close-id">
            <% (deptOpenCases||[]).forEach(function(c){ %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %></option><% }); %>
          </select>
        </div>
        <div class="form-group"><label>Reason</label><input class="form-control" id="dc-close-reason" placeholder="Closing reason…"></div>
        <button class="btn btn-primary btn-sm" onclick="deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/case-close',{caseId:document.getElementById('dc-close-id').value,reason:document.getElementById('dc-close-reason').value},'dc-close-result')">Close Case</button>
        <div id="dc-close-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">📌</span><div class="cmd-card-title">Assign Case</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Case</label>
          <select class="form-control" id="dc-assign-id">
            <% (deptCases||[]).forEach(function(c){ %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %></option><% }); %>
          </select>
        </div>
        <div class="form-group"><label>Assign To</label>
          <select class="form-control" id="dc-assign-user">
            <% (members||[]).forEach(function(m){ %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
          </select>
        </div>
        <button class="btn btn-primary btn-sm" onclick="deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/case-assign',{caseId:document.getElementById('dc-assign-id').value,userId:document.getElementById('dc-assign-user').value},'dc-assign-result')">Assign</button>
        <div id="dc-assign-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">📸</span><div class="cmd-card-title">Add Evidence</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Case</label>
          <select class="form-control" id="dc-evi-id">
            <% (deptCases||[]).forEach(function(c){ %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %></option><% }); %>
          </select>
        </div>
        <div class="form-group"><label>Description</label><textarea class="form-control" id="dc-evi-desc" rows="2" placeholder="Evidence details…"></textarea></div>
        <button class="btn btn-primary btn-sm" onclick="deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/evidence-add',{caseId:document.getElementById('dc-evi-id').value,description:document.getElementById('dc-evi-desc').value},'dc-evi-result')">Add Evidence</button>
        <div id="dc-evi-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">🗑️</span><div class="cmd-card-title">Delete Case</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Case</label>
          <select class="form-control" id="dc-del-id">
            <% (deptCases||[]).forEach(function(c){ %><option value="<%= c.id %>"><%= c.id %> — <%= c.title %></option><% }); %>
          </select>
        </div>
        <div class="form-group"><label>Type YES to confirm</label><input class="form-control" id="dc-del-confirm" placeholder="YES"></div>
        <button class="btn btn-sm" style="background:#c0392b;color:#fff;border:none;" onclick="deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/case-delete',{caseId:document.getElementById('dc-del-id').value,confirmation:document.getElementById('dc-del-confirm').value},'dc-del-result')">🗑️ Delete</button>
        <div id="dc-del-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
  </div>
</div><!-- end dtab-cases -->

<!-- ─── LOA Manager tab panel ─────────────────────────────────────────────── -->
<div id="dtab-loa" class="tab-panel">
  <div class="card" style="margin-bottom:16px;">
    <div class="card-header"><h3 class="card-title">🌴 Currently On LOA (<%= (usersOnLoa||[]).length %>)</h3></div>
    <div class="card-body">
      <% if (!(usersOnLoa||[]).length) { %>
        <p style="color:var(--text-muted);">No members currently on LOA for this department.</p>
      <% } else { %>
        <% (usersOnLoa||[]).forEach(function(u){ %>
          <div style="padding:10px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
            <span><strong><%= u.name %></strong></span>
            <span style="font-size:12px;color:var(--text-muted);"><%= u.startDate %> → <%= u.endDate %></span>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>
  <div class="cmd-grid">
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">🌴</span><div class="cmd-card-title">Set LOA</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Member</label>
          <select class="form-control" id="dloa-user">
            <% (members||[]).forEach(function(m){ %><option value="<%= m.id %>"><%= m.name %></option><% }); %>
          </select>
        </div>
        <div class="form-group"><label>Start Date (MM-DD-YYYY)</label><input class="form-control" id="dloa-start" placeholder="03-01-2026"></div>
        <div class="form-group"><label>End Date (MM-DD-YYYY)</label><input class="form-control" id="dloa-end" placeholder="03-15-2026"></div>
        <div class="form-group"><label>Reason (optional)</label><input class="form-control" id="dloa-reason" placeholder="Vacation, medical…"></div>
        <button class="btn btn-primary btn-sm" onclick="deptLOAAction()">Set LOA</button>
        <div id="dloa-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
    <% if ((usersOnLoa||[]).length > 0) { %>
    <div class="cmd-card">
      <div class="cmd-card-header"><span class="cmd-card-icon">✅</span><div class="cmd-card-title">End LOA</div></div>
      <div class="cmd-card-body">
        <div class="form-group"><label>Member</label>
          <select class="form-control" id="dloa-end-user">
            <% (usersOnLoa||[]).forEach(function(u){ %><option value="<%= u.id %>"><%= u.name %></option><% }); %>
          </select>
        </div>
        <button class="btn btn-primary btn-sm" onclick="deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/end-loa',{userId:document.getElementById('dloa-end-user').value},'dloa-end-result')">End LOA</button>
        <div id="dloa-end-result" style="display:none;margin-top:10px;padding:8px;border-radius:6px;"></div>
      </div>
    </div>
    <% } %>
  </div>
</div><!-- end dtab-loa -->

<!-- ─── View Logs tab panel ────────────────────────────────────────────────── -->
<div id="dtab-logs" class="tab-panel">
  <div class="card">
    <div class="card-header"><h3 class="card-title">⚖️ Strike Log</h3></div>
    <div class="card-body">
      <% if (!(deptStrikeLogs||[]).length) { %>
        <p style="color:var(--text-muted);">No strikes on record for this department.</p>
      <% } else { %>
        <div style="overflow-x:auto;">
          <table class="table" style="min-width:520px;">
            <thead><tr><th>Member</th><th>Reason</th><th>Given By</th><th>Date</th></tr></thead>
            <tbody>
              <% (deptStrikeLogs||[]).forEach(function(log){ %>
              <tr>
                <td style="font-weight:600;color:var(--text-primary);"><%= log.name %></td>
                <td><%= log.reason %></td>
                <td style="font-size:12px;color:var(--text-muted);"><%= log.givenBy %></td>
                <td style="font-size:12px;color:var(--text-muted);white-space:nowrap;"><%= log.date %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div><!-- end dtab-logs -->

<!-- ── Action modal ───────────────────────────────────────────────────────── -->
<div class="modal-overlay" id="actionModal" data-max-strikes="<%= MAX_STRIKES %>">
  <div class="modal-box">
    <h3 class="modal-title" id="modalTitle">Action</h3>
    <div id="modalFields"></div>
    <div style="display:flex;gap:10px;margin-top:18px;">
      <button class="btn btn-primary" onclick="submitModal()" id="modalSubmitBtn">Confirm</button>
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
    </div>
    <div id="modalResult" style="margin-top:12px;display:none;"></div>
  </div>
</div>

<script>
  var GUILD_ID = '<%= guildId %>';
  var MAX_STRIKES = parseInt(document.getElementById('actionModal').dataset.maxStrikes, 10);
  var currentAction = null;
  var currentUserId = null;

  var ACTIONS = {
    strike:  { title:'⚖️ Give Strike',   endpoint:'/api/guild/'+GUILD_ID+'/strike',   fields:['reason'] },
    timeout: { title:'⏱ Timeout Member', endpoint:'/api/guild/'+GUILD_ID+'/timeout',  fields:['minutes','reason'] },
    kick:    { title:'👢 Kick Member',    endpoint:'/api/guild/'+GUILD_ID+'/kick',     fields:['reason'] },
    ban:     { title:'🔨 Ban Member',     endpoint:'/api/guild/'+GUILD_ID+'/ban',      fields:['reason'] }
  };
    ACTIONS['strike-remove'] = { title:'❌ Remove Strike', endpoint:'/api/guild/'+GUILD_ID+'/strike-remove', fields:['amount'] };

  function openModal(action, userId, name) {
    currentAction = action;
    currentUserId = userId;
    var cfg = ACTIONS[action];
    document.getElementById('modalTitle').textContent = cfg.title + ' — ' + name;
    var html = '<input type="hidden" id="mUserId" value="'+userId+'">';
    if (cfg.fields.includes('minutes')) {
      html += '<div class="form-group"><label>Duration (minutes)</label><input class="form-control" id="mMinutes" type="number" min="1" max="40320" value="60"></div>';
    }
    if (cfg.fields.includes('reason')) {
      html += '<div class="form-group"><label>Reason</label><input class="form-control" id="mReason" type="text" placeholder="Enter reason…"></div>';
    }
      if (cfg.fields.includes('amount')) {
        html += '<div class="form-group"><label>Strikes to Remove</label><input class="form-control" id="mAmount" type="number" min="1" max="'+MAX_STRIKES+'" value="1"></div>';
      }
    document.getElementById('modalFields').innerHTML = html;
    document.getElementById('modalResult').style.display = 'none';
    document.getElementById('actionModal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('actionModal').classList.remove('open');
  }

  async function submitModal() {
    var cfg = ACTIONS[currentAction];
    var body = { userId: currentUserId };
    var reasonEl  = document.getElementById('mReason');
    var minutesEl = document.getElementById('mMinutes');
    var amountEl  = document.getElementById('mAmount');
    if (reasonEl)  body.reason  = reasonEl.value.trim();
    if (minutesEl) body.minutes = minutesEl.value;
    if (amountEl)  body.amount  = amountEl.value;

    if (!body.reason && cfg.fields.includes('reason')) {
      showModalResult('error', 'Please enter a reason.');
      return;
    }

    var btn = document.getElementById('modalSubmitBtn');
    btn.disabled = true;
    btn.textContent = 'Working…';

    try {
      var res = await fetch(cfg.endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      var data = await res.json();
      if (data.success) {
        showModalResult('ok', 'Done! ' + (data.totalStrikes !== undefined ? 'Strikes: '+data.totalStrikes+'/'+MAX_STRIKES : ''));
        setTimeout(function(){ closeModal(); location.reload(); }, 1200);
      } else {
        showModalResult('error', data.error || 'Something went wrong.');
      }
    } catch(e) {
      showModalResult('error', 'Request failed: ' + e.message);
    }
    btn.disabled = false;
    btn.textContent = 'Confirm';
  }

  function showModalResult(type, msg) {
    var el = document.getElementById('modalResult');
    el.style.display = 'block';
    el.className = type === 'ok' ? 'alert alert-success' : 'alert alert-danger';
    el.textContent = msg;
  }

  function filterMembers() {
    var q = document.getElementById('memberSearch').value.toLowerCase();
    document.querySelectorAll('#memberTable tbody tr').forEach(function(row) {
      var name = row.dataset.name || '';
      var user = row.dataset.username || '';
      row.style.display = (name.includes(q) || user.includes(q)) ? '' : 'none';
    });
  }

  document.getElementById('actionModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

    // ── Department tab switching ──────────────────────────────────────────────
    var DEPT_GUILD_ID = '<%= guildId %>';
    document.querySelectorAll('.tab-btn[data-dtab]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tab-btn[data-dtab]').forEach(function(b){ b.classList.remove('active'); });
        document.querySelectorAll('#dtab-members,#dtab-cases,#dtab-loa,#dtab-logs').forEach(function(p){ p.classList.remove('active'); });
        this.classList.add('active');
        var panel = document.getElementById(this.dataset.dtab);
        if (panel) panel.classList.add('active');
      });
    });

    // ── Department AJAX helper ────────────────────────────────────────────────
    async function deptCaseAction(endpoint, body, resultId) {
      var el = document.getElementById(resultId);
      if (el) el.style.display = 'none';
      try {
        var r = await fetch(endpoint, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
        var d = await r.json();
        if (el) {
          el.style.display = 'block';
          el.style.color = d.success ? '#2ecc71' : '#e74c3c';
          el.style.background = d.success ? 'rgba(46,204,113,.12)' : 'rgba(231,76,60,.12)';
          el.style.border = '1px solid ' + (d.success ? '#2ecc7150' : '#e74c3c50');
          el.textContent = d.message || d.error || (d.success ? 'Done!' : 'Something went wrong.');
        }
      } catch(e) {
        if (el) { el.style.display='block'; el.style.color='#e74c3c'; el.textContent='Request failed: '+e.message; }
      }
    }

    function deptCaseCreate() {
      var joint = document.getElementById('dc-joint') && document.getElementById('dc-joint').checked;
      deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/case-create', {
        title:        document.getElementById('dc-title').value,
        incidentType: document.getElementById('dc-type').value,
        location:     document.getElementById('dc-loc').value,
        suspect:      document.getElementById('dc-suspect').value,
        summary:      document.getElementById('dc-summary').value,
        jointOps:     joint ? 'true' : 'false'
      }, 'dc-result');
    }

    function deptLOAAction() {
      deptCaseAction('/api/guild/'+DEPT_GUILD_ID+'/loa', {
        userId:    document.getElementById('dloa-user').value,
        startDate: document.getElementById('dloa-start').value,
        endDate:   document.getElementById('dloa-end').value,
        reason:    document.getElementById('dloa-reason') ? document.getElementById('dloa-reason').value : ''
      }, 'dloa-result');
    }
</script>

