<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : (typeof branding !== 'undefined' ? branding.dashboardTitle : 'Twin Palms Roleplay — Control Panel') %></title>
  <link rel="stylesheet" href="/css/dashboard.css">
  <style>
    :root { --accent: #F8B637; --accent-dark: #d9982b; }
    .topbar-brand { gap: 10px; }
    .tp-logo { font-size: 20px; font-weight: 800; color: #F8B637; letter-spacing: 0.02em; }
    .sidebar-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); padding: 12px 16px 4px; }
  </style>
</head>
<body>

<!-- Top Navigation Bar -->
<header class="topbar">
  <div class="topbar-brand">
    <% if (botAvatar) { %>
      <img src="<%= botAvatar %>" alt="" class="topbar-avatar" onerror="this.style.display='none'">
    <% } %>
    <span class="tp-logo">🌴 Twin Palms Roleplay</span>
    <span class="topbar-badge">Control Panel</span>
  </div>
  <div class="topbar-user">
    <% if (user) { %>
      <img src="<%= user.avatar %>" alt="" class="topbar-user-avatar" onerror="this.style.display='none'">
      <span class="topbar-username"><%= user.username %></span>
      <a href="/auth/logout" class="btn btn-sm btn-outline">Logout</a>
    <% } %>
  </div>
</header>

<div class="layout">

  <!-- Sidebar -->
  <aside class="sidebar">
    <nav class="sidebar-nav">
      <div class="sidebar-section-label">Main</div>
      <% if (!segmentAccess || segmentAccess.home) { %>
        <a href="/"         class="nav-link <%= page === 'home'       ? 'active' : '' %>">
          <span class="nav-icon">🏠</span><span class="nav-label">Home</span>
        </a>
      <% } %>
      <% if (!segmentAccess || segmentAccess.status) { %>
        <a href="/status"   class="nav-link <%= page === 'status'     ? 'active' : '' %>">
          <span class="nav-icon">📊</span><span class="nav-label">Bot Status</span>
        </a>
      <% } %>
      <% if (!segmentAccess || segmentAccess.commands) { %>
        <a href="/commands" class="nav-link <%= page === 'commands'   ? 'active' : '' %>">
          <span class="nav-icon">⚡</span><span class="nav-label">Commands</span>
        </a>
      <% } %>
      <% if (!segmentAccess || segmentAccess.logs) { %>
        <a href="/logs"     class="nav-link <%= page === 'logs'       ? 'active' : '' %>">
          <span class="nav-icon">📋</span><span class="nav-label">Logs</span>
        </a>
      <% } %>
      <% if (!segmentAccess || segmentAccess.settings) { %>
        <a href="/settings" class="nav-link <%= page === 'settings'   ? 'active' : '' %>">
          <span class="nav-icon">⚙️</span><span class="nav-label">Settings</span>
        </a>
      <% } %>
      <% if (isBotOwner && (!segmentAccess || segmentAccess.settings)) { %>
        <a href="/settings#bot-owner-access" class="nav-link">
          <span class="nav-icon">👑</span><span class="nav-label">Bot Owner</span>
        </a>
      <% } %>

      <% if (!segmentAccess || segmentAccess.departments) { %>
        <div class="sidebar-section-label" style="margin-top:8px;">Departments</div>
        <a href="/servers"     class="nav-link <%= page === 'servers'     ? 'active' : '' %>">
          <span class="nav-icon">🌐</span><span class="nav-label">All Servers</span>
        </a>
        <% if (typeof servers !== 'undefined' && servers.length > 0) { %>
          <% servers.forEach(function(srv) { %>
            <a href="/departments/<%= srv.id %>"
               class="nav-link <%= page === 'department' && typeof guildId !== 'undefined' && guildId === srv.id ? 'active' : '' %>"
               title="<%= srv.name %>">
              <span class="nav-icon">🏛️</span>
              <span class="nav-label" style="font-size:12px;"><%= srv.shortName || srv.department %></span>
            </a>
          <% }); %>
        <% } %>
      <% } %>
    </nav>
    <div class="sidebar-footer">
      <span class="sidebar-footer-text">TTRP Dashboard</span>
    </div>
  </aside>

  <!-- Main content starts here — closed in footer.ejs -->
  <main class="main-content">
