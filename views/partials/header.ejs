<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🌴 TTRP Control Panel</title>
  <link rel="icon" href="/images/ttrp-logo.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <style>
    :root { --accent: #F8B637; --accent-dark: #d9982b; }
    .topbar-brand { gap: 10px; }
    .tp-logo { font-size: 20px; font-weight: 800; color: #ffe2a8; letter-spacing: -0.03em; text-shadow: 0 0 24px rgba(248, 182, 55, 0.14); }
    .sidebar-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); padding: 14px 16px 6px; }
  </style>
</head>
<body>

<!-- Mobile nav overlay (click to close sidebar) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Top Navigation Bar -->
<header class="topbar">
  <button class="hamburger" id="hamburgerBtn" aria-label="Open navigation" aria-expanded="false" aria-controls="mainSidebar">
    <span></span><span></span><span></span>
  </button>
  <div class="topbar-brand">
    <% if (botAvatar) { %>
      <img src="<%= botAvatar %>" alt="" class="topbar-avatar" onerror="this.style.display='none'">
    <% } %>
    <span class="tp-logo topbar-title">🌴 Twin Palms Roleplay</span>
    <span class="tp-logo topbar-title-short">🌴 Twin Palms</span>
    <span class="topbar-badge">Control Panel</span>
  </div>
  <div class="topbar-user">
    <% if (user) { %>
      <img src="<%= user.avatar %>" alt="" class="topbar-user-avatar" onerror="this.style.display='none'">
      <span class="topbar-username"><%= user.username %></span>
      <a href="/auth/logout" class="btn btn-sm btn-outline">Logout</a>
    <% } %>
  </div>
</header>

<div class="layout">

  <!-- Sidebar -->
  <aside class="sidebar" id="mainSidebar">
    <nav class="sidebar-nav">
      <div class="sidebar-section-label">Main</div>
      <% if (!segmentAccess || segmentAccess.home) { %>
        <a href="/"         class="nav-link <%= page === 'home'       ? 'active' : '' %>">
          <span class="nav-icon">🏠</span><span class="nav-label">Home</span>
        </a>
      <% } %>

      <% var canSeeStaffSection = (!segmentAccess || segmentAccess.settings); %>
      <% if (canSeeStaffSection) { %>
        <div class="sidebar-section-label" style="margin-top:8px;">Staff</div>
        <% if (!segmentAccess || segmentAccess.status) { %>
          <a href="/status"   class="nav-link <%= page === 'status'     ? 'active' : '' %>">
            <span class="nav-icon">📊</span><span class="nav-label">Bot Status</span>
          </a>
        <% } %>
        <% if (!segmentAccess || segmentAccess.commands) { %>
          <a href="/commands" class="nav-link <%= page === 'commands'   ? 'active' : '' %>">
            <span class="nav-icon">⚡</span><span class="nav-label">Commands</span>
          </a>
        <% } %>
        <% if (!segmentAccess || segmentAccess.logs) { %>
          <a href="/logs"     class="nav-link <%= page === 'logs'       ? 'active' : '' %>">
            <span class="nav-icon">📋</span><span class="nav-label">Logs</span>
          </a>
        <% } %>
        <% var _mainServersForStaff = (typeof servers !== 'undefined' ? servers : []).filter(function(s){
             return (departments[s.id] || {}).type === 'main';
           }); %>
        <% _mainServersForStaff.forEach(function(srv) { %>
          <a href="/departments/<%= srv.id %>"
             class="nav-link <%= page === 'department' && typeof guildId !== 'undefined' && guildId === srv.id ? 'active' : '' %>"
             title="<%= srv.name %>">
            <span class="nav-icon">🏛️</span><span class="nav-label">Twin Palms Staff</span>
          </a>
        <% }); %>
        <% if (!segmentAccess || segmentAccess.applications) { %>
          <a href="/applications" class="nav-link <%= page === 'applications' ? 'active' : '' %>">
            <span class="nav-icon">📝</span><span class="nav-label">Applications</span>
          </a>
        <% } %>
        <% if (!segmentAccess || segmentAccess.settings) { %>
          <a href="/settings" class="nav-link <%= page === 'settings'   ? 'active' : '' %>">
            <span class="nav-icon">⚙️</span><span class="nav-label">Settings</span>
          </a>
        <% } %>
        <% if (isBotOwner) { %>
          <a href="/bot-owner" class="nav-link <%= page === 'bot-owner' ? 'active' : '' %>">
            <span class="nav-icon">👑</span><span class="nav-label">Bot Owner</span>
          </a>
        <% } %>
      <% } %>

      <% if (!segmentAccess || segmentAccess.departments) { %>
        <% var visibleDepartmentIds = Array.isArray(accessibleDepartmentIds) ? accessibleDepartmentIds.map(String) : []; %>
        <% var deptServers = Object.entries(typeof departments !== 'undefined' ? departments : {}).filter(function(entry){
             var dept = entry[1] || {};
             return dept.type === 'department' && (visibleDepartmentIds.length === 0 || visibleDepartmentIds.includes(String(entry[0])));
           }).map(function(entry){
             return {
               id: entry[0],
               name: entry[1].name,
               shortName: entry[1].shortName,
               logo: entry[1].logo
             };
           }); %>
        <div class="sidebar-section-label" style="margin-top:8px;">Law Enforcement</div>
        <a href="/departments/joint" class="nav-link <%= page === 'joint' ? 'active' : '' %>">
          <span class="nav-icon">🤝</span><span class="nav-label">Joint Ops</span>
        </a>
        <% deptServers.forEach(function(srv) { %>
          <a href="/departments/<%= srv.id %>"
             class="nav-link <%= page === 'department' && typeof guildId !== 'undefined' && guildId === srv.id ? 'active' : '' %>"
             title="<%= srv.name %>">
            <% if (srv.logo) { %>
              <span class="nav-icon" style="display:flex;align-items:center;justify-content:center;width:24px;height:24px;"><img src="<%= srv.logo %>" alt="" style="width:24px;height:24px;border-radius:4px;object-fit:contain;" onerror="this.parentElement.textContent='🏛️'"></span>
            <% } else { %>
              <span class="nav-icon">🏛️</span>
            <% } %>
            <span class="nav-label" style="font-size:12px;"><%= srv.shortName || srv.name %></span>
          </a>
        <% }); %>
        <a href="/servers" class="nav-link <%= page === 'servers' ? 'active' : '' %>">
          <span class="nav-icon">🌐</span><span class="nav-label">All Servers</span>
        </a>
      <% } %>
    </nav>
    <div class="sidebar-footer">
      <span class="sidebar-footer-text">TTRP Dashboard</span>
    </div>
  </aside>

  <!-- Main content starts here — closed in footer.ejs -->
  <main class="main-content">

<script>
(function() {
  var btn      = document.getElementById('hamburgerBtn');
  var sidebar  = document.getElementById('mainSidebar');
  var overlay  = document.getElementById('sidebarOverlay');
  if (!btn || !sidebar || !overlay) return;

  function openNav() {
    sidebar.classList.add('sidebar--open');
    overlay.classList.add('sidebar-overlay--visible');
    btn.setAttribute('aria-expanded', 'true');
    btn.classList.add('hamburger--open');
    document.body.style.overflow = 'hidden';
  }

  function closeNav() {
    sidebar.classList.remove('sidebar--open');
    overlay.classList.remove('sidebar-overlay--visible');
    btn.setAttribute('aria-expanded', 'false');
    btn.classList.remove('hamburger--open');
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', function() {
    sidebar.classList.contains('sidebar--open') ? closeNav() : openNav();
  });

  overlay.addEventListener('click', closeNav);

  // Close sidebar when a nav link is tapped on mobile
  sidebar.querySelectorAll('.nav-link').forEach(function(link) {
    link.addEventListener('click', function() {
      if (window.innerWidth <= 768) closeNav();
    });
  });

  // Close if window resizes past breakpoint
  window.addEventListener('resize', function() {
    if (window.innerWidth > 768) closeNav();
  });
}());
</script>
