<%- include('partials/header') %>

<style>
  .server-identity {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .server-logo {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    object-fit: contain;
    flex-shrink: 0;
    background: rgba(255,255,255,0.04);
    padding: 2px;
  }
  .department-cell {
    min-width: 220px;
    max-width: 360px;
    white-space: normal;
  }
</style>

<div class="page-header">
  <h2 class="page-title">🌐 All Servers</h2>
  <p class="page-subtitle">
    <%= servers.length %> server<%= servers.length !== 1 ? 's' : '' %> &nbsp;·&nbsp;
    <%= totalMembers.toLocaleString() %> total members
  </p>
</div>

<div class="stats-grid" style="margin-bottom:24px;">
  <div class="stat-card">
    <div class="stat-icon">🏘️</div>
    <div class="stat-body">
      <div class="stat-value"><%= servers.length %></div>
      <div class="stat-label">Servers</div>
    </div>
  </div>
  <div class="stat-card stat-card--info">
    <div class="stat-icon">👥</div>
    <div class="stat-body">
      <div class="stat-value"><%= totalMembers.toLocaleString() %></div>
      <div class="stat-label">Total Members</div>
    </div>
  </div>
  <div class="stat-card stat-card--ok">
    <div class="stat-icon">🟢</div>
    <div class="stat-body">
      <div class="stat-value"><%= servers.filter(s => s.online).length %></div>
      <div class="stat-label">Online</div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">📋 Department Overview</h3>
  </div>
  <div class="card-body" style="padding:0;">
    <% if (servers.length === 0) { %>
      <p style="padding:24px; color:var(--text-muted);">No servers found.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Server</th>
            <th>Department</th>
            <th>Members</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% servers.forEach(srv => { %>
          <tr>
            <td>
              <div class="server-identity">
                <% if (srv.logo) { %>
                  <img src="<%= srv.logo %>" alt="" class="server-logo" onerror="this.style.display='none'">
                <% } else if (srv.icon) { %>
                  <img src="<%= srv.icon %>" alt="" class="server-logo" onerror="this.style.display='none'">
                <% } else { %>
                  <div style="width:32px;height:32px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px;">🏘️</div>
                <% } %>
                <div>
                  <div style="font-weight:600;color:var(--text-primary);"><%= srv.name %></div>
                  <div style="font-size:11px;color:var(--text-muted);">ID: <%= srv.id %></div>
                </div>
              </div>
            </td>
            <td class="department-cell">
              <span class="badge dept-badge" data-color="<%= srv.color %>">
                <%= srv.department %>
              </span>
            </td>
            <td><%= srv.memberCount.toLocaleString() %></td>
            <td>
              <% if (srv.online) { %>
                <span class="badge badge-ok">🟢 Online</span>
              <% } else { %>
                <span class="badge badge-danger">🔴 Offline</span>
              <% } %>
            </td>
            <td>
              <a href="/departments/<%= srv.id %>" class="btn btn-sm btn-outline">View</a>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<script>
  document.querySelectorAll('.dept-badge[data-color]').forEach(function(el) {
    var c = el.dataset.color;
    el.style.background = c + '22';
    el.style.color = c;
    el.style.border = '1px solid ' + c + '44';
  });
</script>

<%- include('partials/footer') %>
