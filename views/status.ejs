<%- include('partials/header') %>

<div class="page-header">
  <h2 class="page-title">📊 Bot Status</h2>
  <p class="page-subtitle">Live system information</p>
</div>

<div class="stats-grid">
  <div class="stat-card <%= online ? 'stat-card--success' : 'stat-card--danger' %>">
    <div class="stat-icon"><%= online ? '🟢' : '🔴' %></div>
    <div class="stat-body">
      <div class="stat-value"><%= online ? 'Online' : 'Offline' %></div>
      <div class="stat-label">Bot Status</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">🏓</div>
    <div class="stat-body">
      <div class="stat-value" id="live-ping"><%= ping %>ms</div>
      <div class="stat-label">WebSocket Ping</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">🏘️</div>
    <div class="stat-body">
      <div class="stat-value"><%= guildCount %></div>
      <div class="stat-label">Servers</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">⚙️</div>
    <div class="stat-body">
      <div class="stat-value"><%= nodeVersion %></div>
      <div class="stat-label">Node.js Version</div>
    </div>
  </div>
</div>

<div class="stats-grid" style="margin-top:12px;">
  <div class="stat-card">
    <div class="stat-icon">⏱️</div>
    <div class="stat-body">
      <div class="stat-value" id="live-uptime"><%
        const h = Math.floor(uptimeSeconds / 3600);
        const m = Math.floor((uptimeSeconds % 3600) / 60);
        const s = uptimeSeconds % 60;
      %><%= h %>h <%= m %>m <%= s %>s</div>
      <div class="stat-label">Uptime</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">💾</div>
    <div class="stat-body">
      <div class="stat-value" id="live-heap"><%= heapUsed %>/<%= heapTotal %> MB</div>
      <div class="stat-label">Heap Memory</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">🖥️</div>
    <div class="stat-body">
      <div class="stat-value" id="live-rss"><%= rss %> MB</div>
      <div class="stat-label">RSS Memory</div>
    </div>
  </div>
</div>

<!-- Memory bar -->
<div class="section-card" style="margin-top:24px;">
  <h3 class="section-title">Heap Usage</h3>
  <div class="progress-bar-wrap">
    <div class="progress-bar-fill" id="heap-bar"
         style="width:<%= Math.min(100, Math.round(heapUsed/heapTotal*100)) %>%"></div>
  </div>
  <p class="progress-label"><%= heapUsed %> MB used of <%= heapTotal %> MB</p>
</div>

<script>
  // Poll live stats every 5 seconds
  setInterval(async () => {
    try {
      const r = await fetch("/api/stats");
      const d = await r.json();
      document.getElementById("live-ping").textContent   = d.ping + "ms";
      document.getElementById("live-rss").textContent    = d.heapUsed + "/" + d.heapTotal + " MB";
      document.getElementById("live-heap").textContent   = d.heapUsed + "/" + d.heapTotal + " MB";
      const pct = Math.min(100, Math.round(d.heapUsed / d.heapTotal * 100));
      document.getElementById("heap-bar").style.width = pct + "%";

      const u = d.uptime;
      const h = Math.floor(u/3600), m = Math.floor((u%3600)/60), s = u%60;
      document.getElementById("live-uptime").textContent = h+"h "+m+"m "+s+"s";
    } catch (e) { /* ignore */ }
  }, 5000);
</script>

<%- include('partials/footer') %>
